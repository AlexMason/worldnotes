{
  "name": "worldnotes",
  "version": "0.1.0",
  "description": "Extensible inline-markdown editor with wiki-style navigation",
  "type": "module",
  "main": "./dist/worldnotes.umd.cjs",
  "module": "./dist/worldnotes.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/worldnotes.js",
      "require": "./dist/worldnotes.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "vite build --watch",
    "test": "node test/cursor.test.mjs && node test/navigation.test.mjs && node test/renderer.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
