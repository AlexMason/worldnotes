{
  "name": "worldnotes",
  "version": "0.1.0",
  "description": "Extensible inline-markdown editor with wiki-style navigation",
  "type": "module",
  "main": "./dist/worldnotes.umd.cjs",
  "module": "./dist/worldnotes.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/worldnotes.js",
      "require": "./dist/worldnotes.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
